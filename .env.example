# Скопируйте в файл `.env` в корне backend и подставьте свои значения.
# Файл `.env` не коммитьте (секреты).

# PostgreSQL (обязательно при отличии от значения по умолчанию)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/finflow

# Google Gemini — короткие советы на дашборде и три пункта в аналитике.
# Ключ: https://ai.google.dev/gemini-api/docs/quickstart?hl=ru
GEMINI_API_KEY=

# Модель (подставьте доступную для вашего ключа и региона)
# Примеры: gemini-2.0-flash, gemini-2.5-flash, gemini-3-flash-preview
GEMINI_MODEL=gemini-2.0-flash
